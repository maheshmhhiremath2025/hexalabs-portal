# Azure credentials
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
SUBSCRIPTION_ID=

# App config
NODE_ENV=production
PORT=8001
MONGO_URI=mongodb://mongodb:27017/cloudportal
JWT_SECRET=
REDIS_HOST=redis

# CORS (comma-separated origins)
CORS_ORIGINS=https://www.getlabs.cloud,https://getlabs.cloud,https://portal.synergificsoftware.com

# Email
GMAIL_USER=
GMAIL_PASS=

# Razorpay
RAZORPAY_ID=
RAZORPAY_KEY=

# Guacamole (browser-based VM access)
GUACAMOLE_URL=http://guacamole:8080/guacamole
GUACAMOLE_PUBLIC_URL=https://labs.getlabs.cloud/guacamole
GUACAMOLE_ADMIN_USER=guacadmin
GUACAMOLE_ADMIN_PASS=guacadmin
# Scale guacd replicas based on concurrent Windows VM count:
# 1 = up to 80 sessions, 5 = up to 400, 10 = up to 800
GUACD_REPLICAS=1
GUACAMOLE_REPLICAS=1

# Docker containers
CONTAINER_HOST_IP=your-server-public-ip
DOCKER_SOCKET=/var/run/docker.sock
CONTAINER_PORT_START=10000
CONTAINER_PORT_END=11000

# Kubernetes (when using AKS)
K8S_IN_CLUSTER=false
K8S_NAMESPACE=lab-containers
LABS_DOMAIN=labs.getlabs.cloud
